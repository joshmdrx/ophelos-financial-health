# Copy to .env and adjust for your environment.
# Both backend and (optionally) frontend dev tooling read from here.

# --- Backend ---

# SQLAlchemy URL. SQLite file lives next to the backend by default.
DATABASE_URL=sqlite:///./financial_health.db

# Comma-separated list of origins allowed to call the API.
CORS_ORIGINS=http://localhost:5173

# uvicorn bind
API_HOST=127.0.0.1
API_PORT=8000

# debug | info | warning | error
LOG_LEVEL=info

# Set to "test" to swap in an in-memory SQLite for the test suite.
APP_ENV=dev

# --- Frontend ---

# Base URL the React app uses to reach the API.
# Just the origin — the generated SDK includes the /api prefix on each path.
VITE_API_BASE_URL=http://localhost:8000
